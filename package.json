{
  "name": "work-fox",
  "version": "0.0.12",
  "description": "Workflow + AI Agent 桌面应用",
  "author": "hunmer",
  "packageManager": "pnpm@10.17.1",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev-win": "chcp 65001 && electron-vite dev",
    "dev:backend": "node scripts/backend-dev.mjs",
    "build:backend": "tsc -p tsconfig.backend.json",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts",
    "preview:web": "vite preview --config vite.web.config.ts",
    "build": "pnpm build:backend && electron-vite build",
    "preview": "electron-vite preview",
    "pack:release": "node scripts/build-production.js release",
    "pack:dir": "pnpm build:backend && npx electron-vite build && npx electron-builder --config electron-builder.json --dir"
  },
  "dependencies": {
