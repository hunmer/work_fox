# ===== Backend Configuration =====

# Log level: debug, info, warn, error
WORKFOX_LOG_LEVEL=info

# Authentication token for WebSocket connections (optional but recommended)
# Set this to a secure random string to require authentication
WORKFOX_BACKEND_TOKEN=

# Secret for validating webhook requests (optional)
WORKFOX_HOOK_SECRET=

# ===== Multi-container mode (docker-compose.yml) =====

# Port to expose the web interface on the host
WORKFOX_WEB_PORT=80

# ===== Standalone mode (docker-compose.standalone.yml) =====

# Port to expose the combined server on the host
WORKFOX_PORT=9123
