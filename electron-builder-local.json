{
  "appId": "com.work-fox.app",
  "productName": "WorkFox",
  "electronDist": "node_modules/electron/dist",
  "directories": {
    "output": "dist-app"
  },
  "files": [
    "out/**/*",
    "package.json",
    "node_modules/**/*",
    "!node_modules/**/{README.md,readme.md,README,readme,CHANGELOG.md,CHANGELOG,LICENSE,license,LICENSE.md,.npmignore,.editorconfig,.eslintrc,.eslintrc.js,.eslintrc.json,.eslintrc.yml}",
    "!node_modules/.bin",
    "!node_modules/**/*.{md,ts,map,d.ts}",
    "!node_modules/**/{test,tests,__tests__,example,examples,docs,doc,website,.github,.vscode}"
  ],
  "mac": {
    "target": [{ "target": "dmg", "arch": ["universal"] }],
    "category": "public.app-category.productivity"
  },
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "extraResources": [
    {
      "from": "resources/plugins",
      "to": "plugins",
      "filter": ["**/*"]
    }
  ],
  "compression": "store",
  "asar": true,
  "publish": {
    "provider": "generic",
    "url": "http://192.168.1.200/workfox_updates/"
  }
}
